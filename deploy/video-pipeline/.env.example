# === LUXOR9 Video Pipeline Configuration ===

# Required: At least one of these API keys
HEYGEN_API_KEY=
MUAPI_API_KEY=

# Remotion
REMOTION_PROJECT_DIR=/app/packages/video-engine
REMOTION_OUTPUT_DIR=/app/output/videos

# Server
PORT=4000
VIDEO_BASE_URL=http://localhost:4000

# Optional: Email delivery via Resend
RESEND_API_KEY=

# Optional: SMS delivery via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SMS_FROM=+15005550006

# Chromium (for Remotion rendering in Docker)
CHROMIUM_PATH=/usr/bin/chromium-browser
REMOTION_CHROMIUM_EXECUTABLE=/usr/bin/chromium-browser
