# LUXOR9 - Hierarchical Agentic AI Orchestration System
# Environment Configuration
# =====================================================
# SECURITY NOTE: In production, ensure:
#   - SECRET_KEY is at least 32 characters
#   - DEBUG=false
#   - CORS_ORIGINS is set to your frontend domains
#   - All API keys are set
# =====================================================

# Core
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Security - Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_BURST=10

# CORS - Security
# In development: allows localhost
# In production: set to your frontend domains (comma-separated)
# IMPORTANT: Do NOT set to "*" in production!
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Request-ID

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/luxor9
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# JWT - SECURITY: Generate a strong secret key for production!
# Leave empty for auto-generation (dev only)
# Production: Use a random 64+ character string
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI Providers - Set your API keys here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Model Configuration
DEFAULT_MODEL=gpt-4o-mini
REASONING_MODEL=gpt-4o
FALLBACK_MODELS=gpt-4o-mini,claude-3-haiku-20240307,llama-3-70b-8192

# AI Provider Rate Limits
OPENAI_RPM=10000
ANTHROPIC_RPM=5000
GROQ_RPM=30

# Token Budgets (per cycle per agent)
PRIME_TOKEN_BUDGET=50000
CSUITE_TOKEN_BUDGET=20000
VP_TOKEN_BUDGET=10000
MANAGER_TOKEN_BUDGET=5000
WORKER_TOKEN_BUDGET=2000

# Agent Cycles (seconds)
PRIME_CYCLE=60
CSUITE_CYCLE=30
VP_CYCLE=60
MANAGER_CYCLE=45
WORKER_CYCLE=30

# Stream Configuration
TOTAL_STREAMS=100
STREAMS_PER_CATEGORY=10

# Revenue Targets
DAILY_REVENUE_TARGET=1000.0
MONTHLY_REVENUE_TARGET=30000.0

# External Services - Optional
STRIPE_API_KEY=
RESEND_API_KEY=
SLACK_WEBHOOK_URL=

# Monitoring & Observability
SENTRY_DSN=
HEALTH_CHECK_INTERVAL=30
METRICS_INTERVAL=1
